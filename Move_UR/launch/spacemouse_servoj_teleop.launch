<launch>
    <!-- ============================================================
         SpaceMouse -> UR5e resolved-rate teleop via servoJ.
         POSITION control (quiet, no speedl whine) + continuous servo
         (smooth like the Quest example).

         Prereqs:
           * ur5_bringup running (External Control URP playing on pendant),
             which also loads /robot_description (KDL reads it for the Jacobian).
           * spacenavd running, ros-$ROS_DISTRO-spacenav-node installed.
           * PyKDL + kdl_parser_py:
               sudo apt install ros-$ROS_DISTRO-python-orocos-kdl \
                                ros-$ROS_DISTRO-kdl-parser-py
           * make the node executable once:
               chmod +x $(rospack find Move_UR)/scripts/spacemouse_servoj_teleop.py
         ============================================================ -->

    <arg name="require_deadman" default="false"/>
    <arg name="max_lin_vel"     default="0.08"/>   <!-- m/s   at full deflection -->
    <arg name="max_ang_vel"     default="0.35"/>   <!-- rad/s at full deflection -->
    <arg name="use_gripper"     default="false"/>
    <arg name="start_spacenav"  default="true"/>
    <arg name="debug"           default="false"/>

    <!-- Define the position-streaming controller on the param server so
         controller_manager can load it WITHOUT editing the driver's
         ur5e_controllers.yaml or restarting the driver. The UR driver maps the
         PositionJointInterface to servoJ (MODE_SERVOJ). -->
    <rosparam ns="forward_position_controller">
        type: position_controllers/JointGroupPositionController
        joints:
          - shoulder_pan_joint
          - shoulder_lift_joint
          - elbow_joint
          - wrist_1_joint
          - wrist_2_joint
          - wrist_3_joint
    </rosparam>

    <node if="$(arg start_spacenav)" pkg="spacenav_node" type="spacenav_node"
          name="spacenav" output="screen">
        <param name="zero_when_static"       value="true"/>
        <param name="static_count_threshold" value="30"/>
        <rosparam param="linear_scale">[1.0, 1.0, 1.0]</rosparam>
        <rosparam param="angular_scale">[1.0, 1.0, 1.0]</rosparam>
    </node>

    <node pkg="Move_UR" type="spacemouse_servoj_teleop.py"
          name="spacemouse_servoj_teleop" output="screen">
        <param name="rate"             value="125"/>   <!-- servoJ streaming rate (driver loop is 500 Hz) -->
        <param name="max_lin_vel"      value="$(arg max_lin_vel)"/>
        <param name="max_ang_vel"      value="$(arg max_ang_vel)"/>
        <param name="deadzone"         value="0.2"/>
        <param name="input_scale"      value="1.0"/>
        <param name="vel_smoothing"    value="0.25"/>  <!-- EMA on the twist; lower = smoother/laggier -->
        <param name="damping"          value="0.05"/>  <!-- DLS lambda: raise if it shakes near singularities -->
        <param name="max_joint_speed"  value="1.5"/>   <!-- rad/s, per-joint safety clamp -->
        <param name="require_deadman"  value="$(arg require_deadman)"/>
        <param name="deadman_button"   value="0"/>
        <param name="gripper_button"   value="1"/>
        <param name="use_gripper"      value="$(arg use_gripper)"/>
        <param name="manage_controller" value="true"/>
        <param name="restore_controller" value="scaled_pos_joint_traj_controller"/>
        <param name="base_frame"       value="base"/>     <!-- Jacobian/twist reference frame -->
        <param name="tip_frame"        value="tool0"/>
        <rosparam param="lin_sign">[1.0, 1.0, 1.0]</rosparam>
        <rosparam param="ang_sign">[1.0, 1.0, 1.0]</rosparam>
        <param name="debug"            value="$(arg debug)"/>
    </node>
</launch>
